// AI-Powered Structured Architectural Internship Intelligence Platform
// Complete Database Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// FIRM INTELLIGENCE DATABASE
// ============================================

model Firm {
  id                      String   @id @default(cuid())
  name                    String
  normalizedName          String
  city                    String
  state                   String
  country                 String   @default("India")
  principalArchitect      String?
  yearEstablished         Int?
  category                String?
  scaleCategory           String
  tierCategory            String
  primaryTypology         String
  secondaryTypology       String?
  designOrientation       String
  technicalOrientation    String
  bimIntensity            String
  internshipPotential     String?
  internshipOffered       String?
  siteExposure            String?
  researchIntensity       String?
  applicationMethod       String?
  portfolioEmphasis       String?
  website                 String?
  officialEmail           String?
  isActive                Boolean  @default(true)
  isVerified              Boolean  @default(false)
  dataSource              String?
  notes                   String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  tags                    FirmTag[]
  rankings                FirmRanking[]

  @@index([name])
  @@index([city])
  @@index([state])
  @@index([scaleCategory])
  @@index([tierCategory])
  @@index([primaryTypology])
  @@index([designOrientation])
  @@index([category])
  @@index([internshipOffered])
  @@index([normalizedName])
}

model FirmTag {
  id              String   @id @default(cuid())
  firmId          String
  tagCategory     String
  tagValue        String
  createdAt       DateTime @default(now())

  firm            Firm     @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@index([tagCategory])
  @@index([tagValue])
}

model FirmRanking {
  id              String   @id @default(cuid())
  firmId          String
  rankingType     String
  rankingPosition Int?
  rankingYear     Int      @default(2024)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  firm            Firm     @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@index([rankingType])
}

model Volume {
  id              String   @id @default(cuid())
  volumeNumber    Int      @unique
  title           String
  description     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  chapters        Chapter[]
}

model Chapter {
  id              String   @id @default(cuid())
  volumeId        String
  chapterNumber   Int
  title           String
  content         String?
  skillArea       String?
  difficulty      String?
  relatedChapters String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  volume          Volume   @relation(fields: [volumeId], references: [id], onDelete: Cascade)
  prompts         GptPrompt[]
  images          ChapterImage[]
  references      ChapterReference[]
  assessments     UserAssessment[]

  @@index([skillArea])
  @@index([chapterNumber])
}

model GptPrompt {
  id            String   @id @default(cuid())
  chapterId     String
  promptType    String
  shortQuestion String
  fullPrompt    String
  encodedUrl    String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  chapter       Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
}

model ChapterImage {
  id              String   @id @default(cuid())
  chapterId       String?
  imageName       String
  imageUrl        String
  imageCategory   String
  sourceReference String?
  usageStatus     String   @default("Available")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  chapter         Chapter? @relation(fields: [chapterId], references: [id], onDelete: SetNull)
}

model Tool {
  id             String   @id @default(cuid())
  title          String
  description    String?
  category       String
  googleDriveUrl String
  versionNumber  String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model FeedbackSubmission {
  id             String   @id @default(cuid())
  feedbackType   String
  relatedVolume  Int?
  relatedChapter Int?
  relatedFirmId  String?
  userName       String?
  userEmail      String?
  feedbackText   String
  status         String   @default("New")
  adminNotes     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         String   @default("Editor")
  lastLogin    DateTime?
  activeStatus Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PlatformSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model ChapterReference {
  id            String   @id @default(cuid())
  chapterId     String?
  title         String
  summary       String
  url           String?
  category      String
  source        String?
  skillArea     String?
  firmRelevance String?
  difficulty    String?
  chapterTags   String?
  thumbnailUrl  String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  chapter       Chapter? @relation(fields: [chapterId], references: [id], onDelete: SetNull)

  @@index([category])
  @@index([skillArea])
  @@index([firmRelevance])
}

model UserAIProfile {
  id               String   @id @default(cuid())
  sessionId        String   @unique
  selectedFirmType String?
  selectedFirmId   String?
  skillProfile     String?
  chaptersVisited  String?
  referencesViewed String?
  weakAreas        String?
  strongAreas      String?
  matchScore       Float?   @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([sessionId])
}

model UserAssessment {
  id                String   @id @default(cuid())
  chapterId         String
  sessionId         String
  clarityRating     Int?
  skillRating       Int?
  applicationRating Int?
  userNotes         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  chapter           Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([chapterId])
  @@index([sessionId])
}